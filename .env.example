# .env.example — Copier en .env et garder les valeurs telles quelles pour le dev local
# Ces valeurs correspondent à docker-compose.yml

# PostgreSQL (via Docker)
DATABASE_URL="postgresql://dalem_user:dalem_dev_password@localhost:5432/dalem_pro_dev?schema=public"

# Redis (via Docker)
REDIS_URL="redis://localhost:6379"

# JWT — générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=a_remplacer_par_une_vraie_valeur_aleatoire
JWT_REFRESH_SECRET=a_remplacer_par_une_autre_valeur_aleatoire

# Serveur
PORT=3001
NODE_ENV=development
